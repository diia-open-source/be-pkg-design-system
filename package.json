{
    "name": "@diia-inhouse/design-system",
    "version": "4.0.2",
    "type": "module",
    "description": "Design system types and utils",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./dist/types/*": "./dist/*",
        "./package.json": "./package.json"
    },
    "author": "Diia",
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "npm run genproto && tsdown && cp -r proto dist/proto && npm run postbuild:fix-messagefns-export",
        "postbuild:fix-messagefns-export": "find dist/generated -name '*.d.ts' -exec sh -c 'grep -q \"^interface MessageFns\" \"$1\" && ! grep -q \"export type { MessageFns\" \"$1\" && printf \"\\nexport type { MessageFns };\\n\" >> \"$1\" || true' _ {} \\;",
        "semantic-release": "semantic-release",
        "lint": "oxlint && oxfmt --check . && buf format ./proto --diff --exit-code ",
        "lint-fix": "oxlint --fix && oxfmt . && buf format ./proto --write",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "prepare": "npm run build",
        "find-circulars": "npx madge --circular --extensions ts ./",
        "genproto": "npx genproto --outputDir src/generated"
    },
    "repository": "https://github.com/diia-open-source/be-pkg-design-system",
    "dependencies": {
        "@types/node": "22.14.1"
    },
    "devDependencies": {
        "@bufbuild/buf": "1.66.1",
        "@bufbuild/protobuf": "2.11.0",
        "@diia-inhouse/configs": "7.0.0",
        "@diia-inhouse/genproto": "3.3.1",
        "@diia-inhouse/oxc-config": "1.9.3",
        "lockfile-lint": "4.14.0",
        "oxfmt": "0.47.0",
        "oxlint": "1.62.0",
        "oxlint-tsgolint": "0.22.1",
        "rimraf": "6.1.3",
        "semantic-release": "24.2.3",
        "ts-proto": "2.7.0",
        "tsdown": "0.21.10",
        "typescript": "5.8.3"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package"
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "madge": {
        "tsConfig": "./tsconfig.json"
    },
    "license": "MIT"
}
